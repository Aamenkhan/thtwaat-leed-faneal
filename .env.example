# DeepSeek (recommended — OpenAI-compatible, cheaper)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# WhatsApp Cloud API
WHATSAPP_TOKEN=your-meta-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=thtwaat_verify_token

# Storage (default: excel)
STORAGE_PROVIDER=excel
EXCEL_FILE_PATH=./data/leads.xlsx
# Vercel Blob (OIDC — recommended on Vercel)
# Auto-injected when Blob store is connected to project:
BLOB_STORE_ID=
VERCEL_OIDC_TOKEN=
BLOB_WEBHOOK_PUBLIC_KEY=
BLOB_ACCESS=private

# Legacy static token (optional fallback / local dev via `vercel env pull`)
BLOB_READ_WRITE_TOKEN=

# Google Sheets (optional — use STORAGE_PROVIDER=google or both)
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT=

# Admin dashboard access
ADMIN_API_KEY=change-this-to-a-long-random-secret

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
