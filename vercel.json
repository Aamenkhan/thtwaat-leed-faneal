{
  "version": 2,
  "installCommand": "npm install && npm install --prefix backend",
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api" },
    { "source": "/health/(.*)", "destination": "/api" },
    { "source": "/lead/create", "destination": "/api" },
    { "source": "/leads", "destination": "/api" },
    { "source": "/leads/export", "destination": "/api" },
    { "source": "/settings/youtube", "destination": "/api" },
    { "source": "/settings/content", "destination": "/api" },
    { "source": "/settings/templates", "destination": "/api" },
    { "source": "/settings/reviews", "destination": "/api" },
    { "source": "/payment/config", "destination": "/api" },
    { "source": "/payment/create-order", "destination": "/api" },
    { "source": "/payment/verify", "destination": "/api" },
    { "source": "/webhook/whatsapp", "destination": "/api" }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
